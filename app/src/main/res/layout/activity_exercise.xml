<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- ── CAMERA PREVIEW ─────────────────────────────────────────── -->
    <androidx.camera.view.PreviewView
        android:id="@+id/view_finder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/controls_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:scaleType="fillStart" />

    <!-- ── SKELETON OVERLAY (drawn on top of camera) ──────────────── -->
    <com.google.mediapipe.examples.poselandmarker.OverlayView
        android:id="@+id/overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="@id/view_finder"
        app:layout_constraintBottom_toBottomOf="@id/view_finder"
        app:layout_constraintStart_toStartOf="@id/view_finder"
        app:layout_constraintEnd_toEndOf="@id/view_finder" />

    <!-- ── TOP BAR (overlaid on camera) ───────────────────────────── -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back button -->
        <TextView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="←"
            android:textSize="22sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/circle_button_bg"
            android:clickable="true"
            android:focusable="true" />

        <!-- Exercise title -->
        <TextView
            android:id="@+id/tv_exercise_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PUSH-UPS"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:shadowColor="#AA000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4" />

        <!-- Recording indicator dot -->
        <View
            android:id="@+id/recording_indicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_red"
            android:visibility="gone"
            android:layout_marginEnd="6dp" />

        <!-- Spacer to balance the back button -->
        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

    <!-- ── FEEDBACK TEXT (floating above controls) ─────────────────── -->
    <TextView
        android:id="@+id/tv_feedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="280dp"
        android:text=""
        android:textSize="14sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/feedback_bg"
        android:paddingHorizontal="18dp"
        android:paddingVertical="9dp"
        android:shadowColor="#AA000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="3"
        app:layout_constraintBottom_toTopOf="@id/controls_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="10dp" />

    <!-- ── BOTTOM CONTROLS PANEL ──────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/controls_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/background_dark"
        android:paddingTop="18dp"
        android:paddingBottom="28dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Rep count + Phase row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <!-- Rep counter box -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/counter_bg"
                android:layout_marginEnd="10dp">

                <TextView
                    android:id="@+id/tv_rep_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="54sp"
                    android:textStyle="bold"
                    android:textColor="@color/mp_color_primary"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REPS"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Phase box -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/counter_bg"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tv_phase_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GET READY"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:maxLines="2"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHASE"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- REC and RESET buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_record"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="⏺  REC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/mp_color_primary"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="↺  RESET"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/button_reset"
                android:layout_marginStart="8dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>